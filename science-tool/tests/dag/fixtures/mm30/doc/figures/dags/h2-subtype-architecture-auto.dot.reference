// H2 Subtype architecture — Molecular lineage + secondary events → distinct architectures
// Source of truth: doc/inquiries/h2-subtype-architecture.md
// Target: hypothesis:h2-cytogenetic-distinct-entities (C1-C7)
digraph h2_subtype_architecture {
  rankdir=TB;
  labelloc="t";
  label=<<b>H2 Subtype architecture</b><br/><font point-size="11">Primary lineage + secondary events → divergent mechanisms, shared endpoint (inquiry:h2-subtype-architecture)</font><br/><font point-size="9" color="#555"><i>auto-styled from edges.yaml — color=edge_status, width=|β|, style=HDI-crosses-zero-dashed, arrowhead=identification</i></font>>;
  fontsize=14;
  node [shape=box, style="rounded,filled", fillcolor="#f0f0f0", fontsize=10];
  edge [fontsize=9];

  subgraph cluster_upstream {
    label="Upstream / Exogenous";
    style=dashed; color="#999999";
    coo [label="Cell of origin\n/ precursor state", fillcolor="#ffe0b2"];
    evo [label="Evolutionary state\n/ secondary-hit\nburden", fillcolor="#ffe0b2"];
    non1q_drv [label="Non-1q driver(s)", fillcolor="#ffcdd2", style="rounded,filled,dashed"];
    stage [label="Disease stage\n(MGUS/SMM/\nMM/RRMM)", fillcolor="#ffe0b2"];
  }

  subgraph cluster_lineage {
    label="Primary lineage";
    style=dashed; color="#1565c0";
    lineage [label="Primary molecular\nlineage\n(HD, t(4;14),\nt(11;14), t(14;16))", fillcolor="#bbdefb", penwidth=2];
    baseline [label="Baseline subtype\narchitecture", fillcolor="#bbdefb"];
  }

  subgraph cluster_secondary {
    label="Secondary events";
    style=dashed; color="#e65100";
    gain1q [label="gain(1q)", fillcolor="#ffe0b2"];
    del17p [label="del(17p)", fillcolor="#ffe0b2"];
    gain8q [label="gain(8q)", fillcolor="#ffe0b2"];
    muts [label="Mutation\nlandscape\n(KRAS, NRAS,\nTP53)", fillcolor="#ffe0b2"];
  }

  subgraph cluster_mechanism {
    label="Architecture generation";
    style=dashed; color="#2e7d32";
    dosage [label="1q gene\ndosage", fillcolor="#c8e6c9"];
    epi [label="Epigenetic\narchitecture\n(3-way Polycomb)", fillcolor="#c8e6c9"];
    prolif [label="Proliferation\n(latent state;\nscore is proxy)", fillcolor="#c8e6c9", penwidth=2];
    arch_1q [label="1q-associated\narchitecture\n(G2M, PHF19,\nIFN silencing)", fillcolor="#c8e6c9"];
    arch_non1q [label="Alternative\nnon-1q architecture\n(E2F, ribosome)", fillcolor="#c8e6c9"];
  }

  subgraph cluster_outcomes {
    label="Outcomes";
    style=dashed; color="#6a1b9a";
    survival [label="Overall\nsurvival", fillcolor="#e1bee7", penwidth=2];
    drug [label="Drug\nresponse", fillcolor="#e1bee7"];
    clinical [label="Clinical\nphenotype", fillcolor="#e1bee7"];
    burden [label="Tumor\nburden", fillcolor="#e1bee7"];
    treatment [label="Baseline\ntreatment", fillcolor="#e1bee7"];
  }

  // Lineage determination
  coo -> lineage [color="#757575", penwidth=1.0, style="dotted", arrowhead=normal, label="[1]", fontsize=10, fontcolor="#757575"];
  lineage -> baseline [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=normal, label="[2]", fontsize=10, fontcolor="#2e7d32"];

  // Lineage → secondary event propensity
  lineage -> gain1q [color="#1565c0", penwidth=1.6, style="solid", arrowhead=normal, label="[3] propensity", fontsize=10, fontcolor="#1565c0"];
  lineage -> del17p [color="#1565c0", penwidth=1.6, style="solid", arrowhead=normal, label="[4] propensity", fontsize=10, fontcolor="#1565c0"];

  // Evolutionary state → secondary events
  evo -> gain1q [color="#1565c0", penwidth=1.6, style="solid", arrowhead=odot, label="[5]", fontsize=10, fontcolor="#1565c0"];
  evo -> del17p [color="#1565c0", penwidth=1.6, style="solid", arrowhead=odot, label="[6]", fontsize=10, fontcolor="#1565c0"];
  evo -> gain8q [color="#c62828", penwidth=1.2, style="dashed", arrowhead=normal, label="[7]", fontsize=10, fontcolor="#c62828"];
  evo -> muts [color="#1565c0", penwidth=1.6, style="solid", arrowhead=normal, label="[8]", fontsize=10, fontcolor="#1565c0"];
  evo -> burden [color="#757575", penwidth=1.0, style="dotted", arrowhead=normal, label="[9]", fontsize=10, fontcolor="#757575"];

  // Architecture generation
  gain1q -> dosage [color="#757575", penwidth=1.0, style="dotted", arrowhead=normal, label="[10]", fontsize=10, fontcolor="#757575"];
  dosage -> arch_1q [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=normal, label="[11]", fontsize=10, fontcolor="#2e7d32"];
  gain1q -> epi [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=diamond, label="[12] PHF19/PRC2 targeted", fontsize=10, fontcolor="#2e7d32"];
  lineage -> epi [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=normal, label="[13] NSD2 global or neutral", fontsize=10, fontcolor="#2e7d32"];
  epi -> arch_1q [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=normal, label="[14]", fontsize=10, fontcolor="#2e7d32"];
  epi -> arch_non1q [color="#1565c0", penwidth=1.6, style="solid", arrowhead=normal, label="[15]", fontsize=10, fontcolor="#1565c0"];
  baseline -> arch_1q [color="#1565c0", penwidth=1.6, style="solid", arrowhead=normal, label="[16]", fontsize=10, fontcolor="#1565c0"];
  baseline -> arch_non1q [color="#1565c0", penwidth=1.6, style="solid", arrowhead=normal, label="[17]", fontsize=10, fontcolor="#1565c0"];
  non1q_drv -> arch_non1q [color="#1565c0", penwidth=1.6, style="solid", arrowhead=normal, label="[18] positive cause", fontsize=10, fontcolor="#1565c0"];
  gain8q -> arch_non1q [color="#1565c0", penwidth=1.6, style="solid", arrowhead=normal, label="[19] expression not dosage", fontsize=10, fontcolor="#1565c0"];

  // Proliferation as first-class latent state (t153)
  arch_1q -> prolif [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=normal, label="[20] G2M/E2F program", fontsize=10, fontcolor="#2e7d32"];
  arch_non1q -> prolif [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=normal, label="[21] E2F/ribosome program", fontsize=10, fontcolor="#2e7d32"];
  prolif -> survival [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=normal, label="[22] fast cycling → worse OS", fontsize=10, fontcolor="#2e7d32"];
  prolif -> burden [color="#757575", penwidth=1.0, style="dotted", arrowhead=normal, label="[23]", fontsize=10, fontcolor="#757575"];

  // Disease stage confounder
  stage -> burden [color="#757575", penwidth=1.0, style="dotted", arrowhead=normal, label="[24] accumulation", fontsize=10, fontcolor="#757575"];
  stage -> treatment [color="#757575", penwidth=1.0, style="dotted", arrowhead=normal, label="[25] intensity", fontsize=10, fontcolor="#757575"];
  stage -> muts [color="#1565c0", penwidth=1.6, style="solid", arrowhead=normal, label="[26] late hits", fontsize=10, fontcolor="#1565c0"];
  stage -> survival [color="#757575", penwidth=1.0, style="dotted", arrowhead=normal, label="[27] time in disease", fontsize=10, fontcolor="#757575"];
  stage -> arch_1q [color="#1565c0", penwidth=1.6, style="solid", arrowhead=odot, label="[28] progression upregulates", fontsize=10, fontcolor="#1565c0"];
  stage -> arch_non1q [color="#1565c0", penwidth=1.6, style="solid", arrowhead=normal, label="[29] progression upregulates", fontsize=10, fontcolor="#1565c0"];

  // Outcomes
  arch_1q -> survival [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=normal, label="[30]", fontsize=10, fontcolor="#2e7d32"];
  arch_non1q -> survival [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=normal, label="[31]", fontsize=10, fontcolor="#2e7d32"];
  arch_1q -> drug [color="#1565c0", penwidth=1.6, style="solid", arrowhead=normal, label="[32]", fontsize=10, fontcolor="#1565c0"];
  arch_non1q -> drug [color="#c62828", penwidth=1.2, style="dashed", arrowhead=normal, label="[33]", fontsize=10, fontcolor="#c62828"];
  arch_1q -> clinical [color="#1565c0", penwidth=1.6, style="solid", arrowhead=normal, label="[34]", fontsize=10, fontcolor="#1565c0"];
  arch_non1q -> clinical [color="#c62828", penwidth=1.2, style="dashed", arrowhead=normal, label="[35]", fontsize=10, fontcolor="#c62828"];
  lineage -> drug [color="#1565c0", penwidth=1.6, style="solid", arrowhead=normal, label="[36] direct (e.g. BCL2/ venetoclax)", fontsize=10, fontcolor="#1565c0"];
  del17p -> survival [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=normal, label="[37]", fontsize=10, fontcolor="#2e7d32"];
  muts -> survival [color="#1565c0", penwidth=1.6, style="solid", arrowhead=normal, label="[38]", fontsize=10, fontcolor="#1565c0"];
  burden -> survival [color="#757575", penwidth=1.0, style="dotted", arrowhead=normal, label="[39]", fontsize=10, fontcolor="#757575"];
  burden -> treatment [color="#757575", penwidth=1.0, style="dotted", arrowhead=normal, label="[40]", fontsize=10, fontcolor="#757575"];
  burden -> clinical [color="#757575", penwidth=1.0, style="dotted", arrowhead=normal, label="[41]", fontsize=10, fontcolor="#757575"];
  treatment -> survival [color="#757575", penwidth=1.0, style="dotted", arrowhead=normal, label="[42] mediator", fontsize=10, fontcolor="#757575"];
  treatment -> drug [color="#757575", penwidth=1.0, style="dotted", arrowhead=normal, label="[43]", fontsize=10, fontcolor="#757575"];

  // --- Auto-footer legend (two-axis: edge_status + identification) ---
  subgraph cluster_auto_footer_legend {
    rank=sink;
    label="";
    color="#bdbdbd"; style="rounded"; margin=10;
    node [shape=plaintext, fontsize=9];
    footer_legend [label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="5" color="#bdbdbd">
      <tr><td bgcolor="#f5f5f5"><b>Auto legend</b></td><td bgcolor="#f5f5f5">color/width = edge_status</td><td bgcolor="#f5f5f5">arrowhead = identification</td></tr>
      <tr><td><font color="#2e7d32">supported</font></td><td><font color="#1565c0">tentative</font> / <font color="#757575">structural</font> / <font color="#c62828">unknown</font> / <font color="#9e9e9e">eliminated</font></td><td>normal = observational/structural/none; diamond = interventional; odot = longitudinal</td></tr>
    </table>>];
    node [shape=plaintext, fontsize=9];
    lg_supp_a [label="supported"]; lg_supp_b [label=""];
    lg_tent_a [label="tentative"]; lg_tent_b [label=""];
    lg_struct_a [label="structural"]; lg_struct_b [label=""];
    lg_unk_a [label="unknown"]; lg_unk_b [label=""];
    lg_elim_a [label="[x] eliminated"]; lg_elim_b [label=""];
    lg_int_a [label="interventional"]; lg_int_b [label=""];
    lg_long_a [label="longitudinal"]; lg_long_b [label=""];
    lg_supp_a -> lg_supp_b [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=normal];
    lg_tent_a -> lg_tent_b [color="#1565c0", penwidth=1.6, style="solid", arrowhead=normal];
    lg_struct_a -> lg_struct_b [color="#757575", penwidth=1.0, style="dotted", arrowhead=normal];
    lg_unk_a -> lg_unk_b [color="#c62828", penwidth=1.2, style="dashed", arrowhead=normal];
    lg_elim_a -> lg_elim_b [color="#9e9e9e", penwidth=1.0, style="dotted", arrowhead=normal];
    lg_int_a -> lg_int_b [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=diamond];
    lg_long_a -> lg_long_b [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=odot];
  }
}
