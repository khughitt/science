// H1 ↔ H2 bridge — Updated 2026-04-19 after t204 terminal verdict.
//
// 2026-04-18 (t204): Observational route for the cell-state composition channel CLOSED.
// Three converging adjuster frames (t174 tumor PC-maturity, t214 healthy-donor PC-maturity,
// t204 non-PC multitype + 10-stratum subtype) all return no_additional_absorption. The
// composition-link edges (state→ribosome, state→E2F1) are marked [✗] eliminated and kept
// for provenance; they no longer carry live mechanistic claims. Surviving discriminators
// are interventional (t205 MS177 PROTAC primary; t199 L1000 secondary; t200 target-trial
// emulation tertiary).
//
// 2026-04-17 (t203): Boiarsky per-cell bridge reading (t172 Q3 collapse) did NOT replicate
// in Ledergor. The per-cell "Replicated" labels on e2f1→phf19 and ezh2→phf19 are
// downgraded to "Boiarsky-specific; awaiting third cohort."
//
// Prior reframe (2026-04-13, t172): bulk ribosome→E2F1 β=−0.27, but per-cell β≈0 within
// cell-cycle phase → composition-driven, not within-cell molecular edge.
//
// Edge labels show posterior β and P(β>0) from Bayesian fits.
digraph h1_h2_bridge {
  rankdir=LR;
  labelloc="t";
  label=<<b>H1 ↔ H2 bridge — as-of 2026-04-19 (post t204)</b><br/><font point-size="11">edge_status: supported (solid green), tentative (solid blue), eliminated (dotted grey, [✗]). Composition channel closed under observational adjusters; surviving discriminators are interventional.</font><br/><font point-size="9" color="#555"><i>auto-styled from edges.yaml — color=edge_status, width=|β|, style=HDI-crosses-zero-dashed, [I]=interventional, [L]=longitudinal</i></font>>;
  fontsize=14;
  node [shape=box, style="rounded,filled", fillcolor="#f0f0f0", fontsize=11];
  edge [fontsize=9, penwidth=1.6];

  // Nodes
  subgraph cluster_composition {
    label="Cell-state composition (between-sample)";
    style=dashed; color="#999999";
    state [label="Cell-state composition\n(plasmablast ↔ mature PC;\ncycling fraction)", fillcolor="#ffe0b2"];
  }

  rib  [label="Ribosome program\n(mean RPL/RPS)", fillcolor="#f0f0f0"];
  e2f  [label="E2F1", fillcolor="#f0f0f0"];
  ezh  [label="EZH2", fillcolor="#f0f0f0"];
  phf  [label="PHF19", fillcolor="#bbdefb", penwidth=2];
  g1q  [label="gain(1q)", fillcolor="#ffe0b2"];
  os   [label="Overall survival", fillcolor="#c8e6c9", penwidth=2];

  // Composition-driven — ELIMINATED under observational adjusters (t204 terminal verdict,
  // 2026-04-18; decision D8). Retained for provenance; surviving discriminators are interventional
  // (t205 MS177 primary, t199 L1000 secondary, t200 target-trial tertiary).
  state -> rib [color="#9e9e9e", penwidth=1.0, style="dotted", arrowhead=normal, label="[1] [✗] composition link (bulk β=−0.27, P=0.994; per-cell within-phase β≈0)\nβ=−0.27", fontsize=10, fontcolor="#9e9e9e"];
  state -> e2f [color="#9e9e9e", penwidth=1.0, style="dotted", arrowhead=normal, label="[2] [✗] composition link\nβ=−0.11", fontsize=10, fontcolor="#9e9e9e"];

  // Per-cell (Boiarsky only; t203 Ledergor did not replicate the broader per-cell reading)
  e2f -> phf [color="#2e7d32", penwidth=2.3, style="solid", arrowhead=normal, label="[3] β=+0.18, P=0.988 per-cell (Boiarsky); not yet replicated across cohorts\nβ=+0.17", fontsize=10, fontcolor="#2e7d32"];
  ezh -> phf [color="#2e7d32", penwidth=2.9, style="solid", arrowhead=normal, label="[4] β=+0.34, P=1.000 per-cell (Boiarsky); prolif-adj Weak-support P=0.914\nβ=+0.34", fontsize=10, fontcolor="#2e7d32"];

  // Bulk stratum-level (solid blue)
  g1q -> phf [color="#2e7d32", penwidth=3.2, style="solid", arrowhead=normal, label="[5] β=+0.40 direct (~17% via E2F1) bulk 5 datasets\nβ=+0.40", fontsize=10, fontcolor="#2e7d32"];
  g1q -> e2f [color="#1565c0", penwidth=2.4, style="solid", arrowhead=normal, label="[6] partial path\nβ=+0.21", fontsize=10, fontcolor="#1565c0"];

  // Downstream to survival (H1 core, supported)
  phf -> os [color="#2e7d32", penwidth=3.4, style="solid", arrowhead=normal, label="[7] HR≈2.7 (5/5 datasets)\nβ=+0.46 · HR=2.7", fontsize=10, fontcolor="#2e7d32"];

  // --- Auto-legend (two-axis: edge_status + identification) ---
  subgraph cluster_autolegend {
    label=<<b>Legend</b> (auto-styled)  —  color/width = edge_status; double-line = interventional; vee arrow = longitudinal>;
    fontsize=10; color="#999"; style="rounded"; margin=12;
    node [shape=plaintext, fontsize=9];
    lg_supp_a [label="supported"]; lg_supp_b [label=""];
    lg_tent_a [label="tentative"]; lg_tent_b [label=""];
    lg_struct_a [label="structural"]; lg_struct_b [label=""];
    lg_unk_a [label="unknown"]; lg_unk_b [label=""];
    lg_elim_a [label="[✗] eliminated"]; lg_elim_b [label=""];
    lg_int_a [label="[I] interventional"]; lg_int_b [label=""];
    lg_long_a [label="[L] longitudinal"]; lg_long_b [label=""];
    lg_supp_a -> lg_supp_b [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=normal];
    lg_tent_a -> lg_tent_b [color="#1565c0", penwidth=1.6, style="solid", arrowhead=normal];
    lg_struct_a -> lg_struct_b [color="#757575", penwidth=1.0, style="dotted", arrowhead=normal];
    lg_unk_a -> lg_unk_b [color="#c62828", penwidth=1.2, style="dashed", arrowhead=normal];
    lg_elim_a -> lg_elim_b [color="#9e9e9e", penwidth=1.0, style="dotted", arrowhead=normal];
    lg_int_a -> lg_int_b [color="#2e7d32:#ffffff:#2e7d32", penwidth=2.5, style="solid", arrowhead=normal];
    lg_long_a -> lg_long_b [color="#2e7d32", penwidth=2.5, style="solid", arrowhead=vee];
  }
}
